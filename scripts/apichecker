#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON="$ROOT_DIR/.venv/bin/python"
ALEMBIC="$ROOT_DIR/.venv/bin/alembic"
DATA_DIR="$ROOT_DIR/data"
PID_FILE="$DATA_DIR/apichecker.pid"
LOG_FILE="$DATA_DIR/apichecker.log"

configured_port() {
    (
        cd "$ROOT_DIR"
        "$PYTHON" -c "from app.config import settings; print(settings.port)"
    )
}

is_running() {
    [[ -f "$PID_FILE" ]] || return 1
    local pid
    pid="$(cat "$PID_FILE")"
    [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null
}

discover_running_pid() {
    local port pid command
    port="$(configured_port)"
    pid="$(ss -ltnp "( sport = :${port} )" 2>/dev/null \
        | sed -n 's/.*pid=\([0-9][0-9]*\).*/\1/p' \
        | head -n 1)"
    [[ -n "$pid" ]] || return 1
    command="$(ps -p "$pid" -o args= 2>/dev/null || true)"
    if [[ "$command" == *"$ROOT_DIR/.venv/bin/python -m app"* ]]; then
        echo "$pid"
        return
    fi
    return 1
}

sync_pid_file() {
    if is_running; then
        return
    fi
    local discovered
    if discovered="$(discover_running_pid)"; then
        echo "$discovered" >"$PID_FILE"
    fi
}

start() {
    sync_pid_file
    if is_running; then
        echo "API Checker sudah berjalan (PID $(cat "$PID_FILE"))."
        return
    fi

    rm -f "$PID_FILE"
    if [[ ! -x "$PYTHON" ]]; then
        echo "Error: .venv belum tersedia. Ikuti bagian instalasi di README.md." >&2
        exit 1
    fi
    if [[ ! -f "$ROOT_DIR/.env" ]]; then
        echo "Error: file .env belum tersedia." >&2
        exit 1
    fi

    mkdir -p "$DATA_DIR"
    cd "$ROOT_DIR"
    local port
    port="$(configured_port)"
    if ! "$ALEMBIC" upgrade head >>"$LOG_FILE" 2>&1; then
        echo "Migrasi database gagal. Periksa $LOG_FILE." >&2
        exit 1
    fi
    nohup "$PYTHON" -m app >>"$LOG_FILE" 2>&1 &
    local pid=$!
    echo "$pid" >"$PID_FILE"

    for _ in {1..20}; do
        if ! kill -0 "$pid" 2>/dev/null; then
            rm -f "$PID_FILE"
            echo "API Checker gagal dijalankan. Periksa $LOG_FILE." >&2
            exit 1
        fi
        if curl --fail --silent "http://127.0.0.1:${port}/healthz" \
            >/dev/null 2>&1; then
            echo "API Checker berjalan di http://127.0.0.1:${port} (PID $pid)."
            return
        fi
        sleep 0.25
    done

    echo "Proses berjalan (PID $pid), tetapi health check belum merespons."
    echo "Periksa log: $LOG_FILE"
}

stop() {
    sync_pid_file
    if ! is_running; then
        rm -f "$PID_FILE"
        echo "API Checker tidak sedang berjalan."
        return
    fi

    local pid
    pid="$(cat "$PID_FILE")"
    kill "$pid"

    for _ in {1..20}; do
        if ! kill -0 "$pid" 2>/dev/null; then
            rm -f "$PID_FILE"
            echo "API Checker sudah dihentikan."
            return
        fi
        sleep 0.25
    done

    echo "Proses belum berhenti setelah 5 detik; mengirim SIGKILL." >&2
    kill -9 "$pid" 2>/dev/null || true
    rm -f "$PID_FILE"
}

status() {
    local port
    port="$(configured_port)"
    sync_pid_file

    if is_running; then
        local pid
        pid="$(cat "$PID_FILE")"
        echo "Status : Running"
        echo "PID    : $pid"
        echo "IP     : 127.0.0.1"
        echo "Port   : $port"
        if curl --fail --silent "http://127.0.0.1:${port}/healthz" >/dev/null 2>&1; then
            echo "Health : OK"
        else
            echo "Health : Tidak merespons"
        fi
    else
        rm -f "$PID_FILE"
        echo "Status : Stopped"
        echo "IP     : 127.0.0.1"
        echo "Port   : $port (tidak aktif)"
        return 1
    fi
}

show_help() {
    echo "Bantuan API Checker"
    echo
    echo "Start  : Menjalankan aplikasi di background."
    echo "Stop   : Menghentikan aplikasi yang dikelola script."
    echo "Status : Menampilkan status, PID, IP, port, dan health check."
    echo "Exit   : Menutup menu tanpa mengubah status aplikasi."
    echo
    echo "Perintah langsung:"
    echo "  $0 start"
    echo "  $0 stop"
    echo "  $0 status"
    echo "  $0 help"
}

show_menu() {
    while true; do
        echo
        echo "API Checker"
        echo
        echo "1. Start"
        echo "2. Stop"
        echo "3. Status"
        echo "4. Help"
        echo "5. Exit"
        echo
        read -r -p "Pilih opsi [1-5]: " choice
        echo

        case "$choice" in
            1) start ;;
            2) stop ;;
            3) status || true ;;
            4) show_help ;;
            5)
                echo "Menu ditutup."
                return
                ;;
            *) echo "Pilihan tidak valid." >&2 ;;
        esac
    done
}

case "${1:-menu}" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        stop
        start
        ;;
    status)
        status
        ;;
    help)
        show_help
        ;;
    menu)
        show_menu
        ;;
    *)
        echo "Penggunaan: $0 [start|stop|status|help]" >&2
        exit 2
        ;;
esac
