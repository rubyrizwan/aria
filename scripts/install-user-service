#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
UNIT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
UNIT_FILE="$UNIT_DIR/apichecker.service"
BACKUP_SERVICE="$UNIT_DIR/apichecker-backup.service"
BACKUP_TIMER="$UNIT_DIR/apichecker-backup.timer"

mkdir -p "$UNIT_DIR"
sed "s|__APP_DIR__|$ROOT_DIR|g" \
    "$ROOT_DIR/deploy/apichecker-user.service" >"$UNIT_FILE"
sed "s|__APP_DIR__|$ROOT_DIR|g" \
    "$ROOT_DIR/deploy/apichecker-backup-user.service" >"$BACKUP_SERVICE"
cp "$ROOT_DIR/deploy/apichecker-backup-user.timer" "$BACKUP_TIMER"
systemctl --user daemon-reload
systemctl --user enable --now apichecker.service
systemctl --user enable --now apichecker-backup.timer
echo "Installed: $UNIT_FILE"
echo "Status: systemctl --user status apichecker.service"
echo "Backup timer: systemctl --user list-timers apichecker-backup.timer"
