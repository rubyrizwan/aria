#!/usr/bin/env python3
from __future__ import annotations

import re
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent


def read_version(path: Path, pattern: str) -> str:
    match = re.search(pattern, path.read_text(), re.MULTILINE)
    if not match:
        raise SystemExit(f"Unable to read version from {path.relative_to(ROOT)}")
    return match.group(1)


app_version = read_version(
    ROOT / "app/version.py", r'^__version__ = "([^"]+)"$'
)
project_version = read_version(
    ROOT / "pyproject.toml", r'^version = "([^"]+)"$'
)

if app_version != project_version:
    raise SystemExit(
        f"Version mismatch: app={app_version}, pyproject={project_version}"
    )

changelog = (ROOT / "CHANGELOG.md").read_text()
if f"## [{app_version}]" not in changelog:
    raise SystemExit(f"CHANGELOG.md has no entry for {app_version}")

readme = (ROOT / "README.md").read_text()
if f"| `{app_version}` |" not in readme:
    raise SystemExit(f"README.md has no version-history row for {app_version}")

tracked = subprocess.run(
    ["git", "ls-files"],
    cwd=ROOT,
    check=True,
    capture_output=True,
    text=True,
).stdout.splitlines()
for path in tracked:
    if (
        path == ".env"
        or path.startswith("data/")
        or path.startswith(".venv/")
        or path.endswith((".db", ".db-shm", ".db-wal", ".log", ".pid"))
    ):
        raise SystemExit(f"Forbidden local artifact is tracked: {path}")

secret_scan = subprocess.run(
    [
        "git",
        "grep",
        "-nE",
        r"(sk-[A-Za-z0-9_-]{16,}|APICHECKER_MASTER_KEY=[A-Za-z0-9_-]{20,})",
        "--",
        ".",
        ":(exclude).env.example",
    ],
    cwd=ROOT,
    capture_output=True,
    text=True,
)
if secret_scan.returncode == 0:
    print(secret_scan.stdout, file=sys.stderr)
    raise SystemExit("Potential secret found in tracked files.")
if secret_scan.returncode not in {0, 1}:
    raise SystemExit("Secret scan failed.")

print(f"Release metadata valid: {app_version}")
