#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MANAGER="${1:-launcher}"

sleep 1
case "$MANAGER" in
    launcher)
        exec "$ROOT_DIR/scripts/aria" restart
        ;;
    systemd-user)
        exec systemctl --user restart apichecker.service
        ;;
    *)
        echo "Unsupported service manager: $MANAGER" >&2
        exit 2
        ;;
esac
