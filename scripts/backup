#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import shutil
import sqlite3
from datetime import datetime
from pathlib import Path

from dotenv import dotenv_values


ROOT = Path(__file__).resolve().parent.parent


def database_path() -> Path:
    env = dotenv_values(ROOT / ".env")
    url = os.getenv(
        "APICHECKER_DATABASE_URL",
        env.get("APICHECKER_DATABASE_URL", "sqlite:///./data/apichecker.db"),
    )
    prefix = "sqlite:///"
    if not str(url).startswith(prefix):
        raise SystemExit("Backup script currently supports SQLite databases only.")
    path = Path(str(url)[len(prefix) :])
    return path if path.is_absolute() else ROOT / path


def prune_backups(destination: Path, keep: int) -> None:
    backups = sorted(
        (path for path in destination.glob("apichecker-*") if path.is_dir()),
        reverse=True,
    )
    for expired in backups[keep:]:
        shutil.rmtree(expired)


def main() -> None:
    parser = argparse.ArgumentParser(description="Create an online API Checker backup.")
    parser.add_argument(
        "--destination",
        type=Path,
        default=ROOT / "backups",
        help="Backup parent directory (default: ./backups).",
    )
    parser.add_argument("--keep", type=int, default=14, help="Backups to retain.")
    args = parser.parse_args()
    if args.keep < 1:
        parser.error("--keep must be at least 1")

    source = database_path()
    if not source.is_file():
        raise SystemExit(f"Database not found: {source}")

    destination = args.destination.expanduser().resolve()
    backup_dir = destination / f"apichecker-{datetime.now().strftime('%Y%m%d-%H%M%S')}"
    backup_dir.mkdir(parents=True, mode=0o700)

    with sqlite3.connect(source) as current, sqlite3.connect(
        backup_dir / "apichecker.db"
    ) as backup:
        current.backup(backup)

    env_file = ROOT / ".env"
    if env_file.is_file():
        shutil.copy2(env_file, backup_dir / "apichecker.env")
        (backup_dir / "apichecker.env").chmod(0o600)
    (backup_dir / "apichecker.db").chmod(0o600)
    prune_backups(destination, args.keep)
    print(backup_dir)


if __name__ == "__main__":
    main()
