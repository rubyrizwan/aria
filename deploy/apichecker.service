[Unit]
Description=API Checker dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=apichecker
Group=apichecker
WorkingDirectory=/opt/apichecker
EnvironmentFile=/opt/apichecker/.env
Environment=APICHECKER_SERVICE_MANAGER=disabled
ExecStartPre=/opt/apichecker/.venv/bin/alembic upgrade head
ExecStart=/opt/apichecker/.venv/bin/python -m app
Restart=always
RestartSec=5
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/opt/apichecker/data

[Install]
WantedBy=multi-user.target
